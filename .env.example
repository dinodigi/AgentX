# Neon (your existing project)
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"

# Platform operators: comma-separated emails that can open every project
ADMIN_EMAILS="you@yourstudio.com"

# Clerk (your existing app)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# Connector secret encryption: 32 random bytes, base64. Generate:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
CONNECTOR_MASTER_KEY="GENERATE_ME"

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID="xxx"
R2_ACCESS_KEY_ID="xxx"
R2_SECRET_ACCESS_KEY="xxx"
R2_BUCKET="agentx-assets"
# Public base URL assets are served from (R2 public bucket or custom domain)
R2_PUBLIC_BASE_URL="https://assets.example.com"

# Bearer secret for POST /api/jobs/drain (min 16 chars). Any scheduler (Netlify
# scheduled fn, Render cron) sends it. Unset => the drain endpoint 503s (fail-closed).
CRON_SECRET=

# Point Stripe API calls at an in-process mock for tests (default https://api.stripe.com in prod)
STRIPE_API_BASE=
