{
  "name": "agentx",
  "version": "0.1.0",
  "private": true,
  "description": "Schema-driven admin layer — MCP-defined data model → branded admin + delivery API",
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx scripts/seed.ts",
    "smoke": "node --env-file=.env --test --test-concurrency=1 \"scripts/smoke/*.test.mjs\"",
    "verify": "npx tsc --noEmit && npm run smoke"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.637.0",
    "@aws-sdk/s3-request-presigner": "^3.637.0",
    "@clerk/nextjs": "^6.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@neondatabase/serverless": "^0.10.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.36.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.23.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "optionalDependencies": {
    "@img/sharp-libvips-linux-x64": "1.3.2",
    "@img/sharp-linux-x64": "0.35.3"
  }
}
